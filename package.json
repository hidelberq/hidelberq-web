{
	"name": "hidelberq-web",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"cf-typegen": "wrangler types",
		"deploy": "react-router build && wrangler deploy",
		"dev": "react-router dev",
		"postinstall": "wrangler types",
		"preview": "react-router build && vite preview",
		"typecheck": "wrangler types && react-router typegen && tsc -b",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply hidelberq-web-db --local",
		"db:migrate:production": "wrangler d1 migrations apply hidelberq-web-db --remote",
		"typegen": "wrangler types"
	},
	"dependencies": {
		"@google/genai": "^1.38.0",
		"@google/generative-ai": "^0.24.1",
		"@tailwindcss/typography": "^0.5.19",
		"budoux": "^0.7.0",
		"drizzle-orm": "^0.45.1",
		"isbot": "^5.1.31",
		"node-html-parser": "^7.0.2",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-markdown": "^10.1.0",
		"react-router": "^7.10.0",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.13.5",
		"@react-router/dev": "^7.10.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22",
		"@types/react": "^19.1.13",
		"@types/react-dom": "^19.1.9",
		"drizzle-kit": "^0.31.8",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
		"vite-tsconfig-paths": "^5.1.4",
		"wrangler": "^4.61.0"
	}
}
